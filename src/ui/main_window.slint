import { VerticalBox } from "std-widgets.slint";
import { AppTitleBar } from "title_bar.slint";
import { WorkspaceShell } from "panels.slint";
import { AppStatusBar } from "status_bar.slint";
import { StartupDialog } from "startup_dialog.slint";

export component MainWindow inherits Window {
    in property <string> project-name;
    in property <string> project-summary;
    in property <string> assets-summary;
    in property <string> queue-summary;
    in property <string> preview-status;
    in property <string> timeline-status;
    in property <string> attributes-status;
    in property <string> status-text;
    in property <string> playback-text;
    in property <bool> can-save-project;
    in property <bool> show-startup-modal;
    in property <bool> startup-can-close;
    in property <bool> startup-can-create;
    in property <string> startup-parent-dir;
    in property <string> startup-name;
    in property <string> startup-width;
    in property <string> startup-height;
    in property <string> startup-fps;
    in property <string> startup-duration-minutes;
    in property <string> startup-preview-max-width;
    in property <string> startup-preview-max-height;
    in property <string> startup-error;

    callback request-new-project();
    callback request-open-project();
    callback request-save-project();
    callback request-open-queue();
    callback request-open-preferences();
    callback request-startup-close();
    callback request-startup-browse-parent();
    callback request-startup-open-project();
    callback request-startup-create-project();
    callback startup-name-edited(string);
    callback startup-width-edited(string);
    callback startup-height-edited(string);
    callback startup-fps-edited(string);
    callback startup-duration-minutes-edited(string);
    callback startup-preview-max-width-edited(string);
    callback startup-preview-max-height-edited(string);

    title: "NLA AI Video Creator";
    preferred-width: 1280px;
    preferred-height: 800px;
    min-width: 1080px;
    min-height: 720px;
    background: #0f172a;

    VerticalBox {
        spacing: 0px;

        AppTitleBar {
            project-name: root.project-name;
            project-summary: root.project-summary;
            can-save-project: root.can-save-project;
            request-new-project => { root.request-new-project(); }
            request-open-project => { root.request-open-project(); }
            request-save-project => { root.request-save-project(); }
            request-open-queue => { root.request-open-queue(); }
            request-open-preferences => { root.request-open-preferences(); }
        }

        Rectangle { height: 1px; background: #1e293b; }

        WorkspaceShell {
            assets-summary: root.assets-summary;
            preview-status: root.preview-status;
            timeline-status: root.timeline-status;
            attributes-status: root.attributes-status;
            queue-summary: root.queue-summary;
        }

        Rectangle { height: 1px; background: #1e293b; }

        AppStatusBar {
            status-text: root.status-text;
            playback-text: root.playback-text;
        }
    }

    if (root.show-startup-modal) : StartupDialog {
        width: parent.width;
        height: parent.height;
        can-close: root.startup-can-close;
        can-create: root.startup-can-create;
        parent-dir: root.startup-parent-dir;
        startup-name: root.startup-name;
        startup-width: root.startup-width;
        startup-height: root.startup-height;
        startup-fps: root.startup-fps;
        startup-duration-minutes: root.startup-duration-minutes;
        startup-preview-max-width: root.startup-preview-max-width;
        startup-preview-max-height: root.startup-preview-max-height;
        error-text: root.startup-error;
        request-close => { root.request-startup-close(); }
        request-browse-parent => { root.request-startup-browse-parent(); }
        request-open-project => { root.request-startup-open-project(); }
        request-create-project => { root.request-startup-create-project(); }
        startup-name-edited(value) => { root.startup-name-edited(value); }
        startup-width-edited(value) => { root.startup-width-edited(value); }
        startup-height-edited(value) => { root.startup-height-edited(value); }
        startup-fps-edited(value) => { root.startup-fps-edited(value); }
        startup-duration-minutes-edited(value) => { root.startup-duration-minutes-edited(value); }
        startup-preview-max-width-edited(value) => { root.startup-preview-max-width-edited(value); }
        startup-preview-max-height-edited(value) => { root.startup-preview-max-height-edited(value); }
    }
}
