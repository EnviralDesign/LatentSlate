import { Button, HorizontalBox, VerticalBox } from "std-widgets.slint";

export component MainWindow inherits Window {
    in property <string> project-name;
    in property <string> project-summary;
    in property <string> assets-summary;
    in property <string> queue-summary;
    in property <string> preview-status;
    in property <string> timeline-status;
    in property <string> attributes-status;
    in property <string> status-text;
    in property <string> playback-text;

    callback request-new-project();
    callback request-open-project();
    callback request-save-project();
    callback request-open-queue();
    callback request-open-preferences();

    title: "NLA AI Video Creator";
    preferred-width: 1280px;
    preferred-height: 800px;
    min-width: 1080px;
    min-height: 720px;
    background: #0f172a;

    VerticalBox {
        spacing: 0px;

        Rectangle {
            height: 56px;
            background: #0b1220;

            HorizontalBox {
                spacing: 12px;
                padding: 12px;

                VerticalBox {
                    spacing: 2px;
                    Text {
                        text: root.project-name;
                        color: #f8fafc;
                        font-size: 18px;
                        font-weight: 600;
                    }
                    Text {
                        text: root.project-summary;
                        color: #94a3b8;
                        font-size: 11px;
                    }
                }

                Rectangle {
                    horizontal-stretch: 1;
                    background: transparent;
                }

                Button {
                    text: "New";
                    clicked => { root.request-new-project(); }
                }
                Button {
                    text: "Open";
                    clicked => { root.request-open-project(); }
                }
                Button {
                    text: "Save";
                    clicked => { root.request-save-project(); }
                }
                Button {
                    text: "Queue";
                    clicked => { root.request-open-queue(); }
                }
                Button {
                    text: "Prefs";
                    clicked => { root.request-open-preferences(); }
                }
            }
        }

        Rectangle { height: 1px; background: #1e293b; }

        HorizontalBox {
            spacing: 0px;

            Rectangle {
                preferred-width: 280px;
                background: #111827;

                VerticalBox {
                    spacing: 10px;
                    padding: 16px;

                    Text {
                        text: "Assets";
                        color: #e2e8f0;
                        font-size: 14px;
                        font-weight: 600;
                    }
                    Text {
                        text: root.assets-summary;
                        color: #94a3b8;
                        font-size: 12px;
                        wrap: word-wrap;
                    }
                    Text {
                        text: "The asset browser is the first real panel migration target after the shared app model and command bus land.";
                        color: #64748b;
                        font-size: 12px;
                        wrap: word-wrap;
                    }
                }
            }

            Rectangle { width: 1px; background: #1e293b; }

            VerticalBox {
                spacing: 0px;
                horizontal-stretch: 1;

                Rectangle {
                    vertical-stretch: 3;
                    background: #020617;

                    VerticalBox {
                        spacing: 12px;
                        padding: 20px;

                        Text {
                            text: "Preview";
                            color: #f8fafc;
                            font-size: 18px;
                            font-weight: 600;
                        }
                        Text {
                            text: root.preview-status;
                            color: #94a3b8;
                            font-size: 13px;
                            wrap: word-wrap;
                        }
                    }
                }

                Rectangle { height: 1px; background: #1e293b; }

                Rectangle {
                    vertical-stretch: 2;
                    background: #111827;

                    VerticalBox {
                        spacing: 12px;
                        padding: 20px;

                        Text {
                            text: "Timeline";
                            color: #f8fafc;
                            font-size: 18px;
                            font-weight: 600;
                        }
                        Text {
                            text: root.timeline-status;
                            color: #94a3b8;
                            font-size: 13px;
                            wrap: word-wrap;
                        }
                    }
                }
            }

            Rectangle { width: 1px; background: #1e293b; }

            Rectangle {
                preferred-width: 320px;
                background: #111827;

                VerticalBox {
                    spacing: 10px;
                    padding: 16px;

                    Text {
                        text: "Attributes";
                        color: #e2e8f0;
                        font-size: 14px;
                        font-weight: 600;
                    }
                    Text {
                        text: root.attributes-status;
                        color: #94a3b8;
                        font-size: 12px;
                        wrap: word-wrap;
                    }
                    Text {
                        text: root.queue-summary;
                        color: #38bdf8;
                        font-size: 12px;
                        wrap: word-wrap;
                    }
                }
            }
        }

        Rectangle { height: 1px; background: #1e293b; }

        Rectangle {
            height: 38px;
            background: #0b1220;

            HorizontalBox {
                spacing: 16px;
                padding: 10px;

                Text {
                    text: root.status-text;
                    color: #cbd5e1;
                    font-size: 12px;
                }

                Rectangle {
                    horizontal-stretch: 1;
                    background: transparent;
                }

                Text {
                    text: root.playback-text;
                    color: #38bdf8;
                    font-size: 12px;
                    font-weight: 600;
                }
            }
        }
    }
}
