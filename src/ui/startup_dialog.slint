import { Button, HorizontalBox, LineEdit, ListView, ScrollView, VerticalBox } from "std-widgets.slint";

/// Padded rail: outer HorizontalBox applies padding; inner Rectangle stretches like the old
/// DebugFrame so @children fill the content box (otherwise nested layouts can collapse to zero).
component RailSection inherits Rectangle {
    in property <length> pad-left;
    in property <length> pad-top;
    in property <length> pad-right;
    in property <length> pad-bottom;

    background: transparent;

    HorizontalBox {
        width: 100%;
        height: 100%;
        spacing: 0px;
        padding-left: root.pad-left;
        padding-top: root.pad-top;
        padding-right: root.pad-right;
        padding-bottom: root.pad-bottom;

        Rectangle {
            min-width: 0px;
            horizontal-stretch: 1;
            vertical-stretch: 1;
            background: transparent;

            @children
        }
    }
}

component StartupFieldRow inherits VerticalBox {
    in property <string> label;
    in property <string> value;
    in property <string> placeholder;
    callback edited(string);

    min-width: 0px;
    preferred-width: 100%;
    horizontal-stretch: 1;
    spacing: 6px;

    Text {
        width: 100%;
        height: 18px;
        vertical-alignment: center;
        horizontal-alignment: left;
        text: root.label;
        color: #8d96a4;
        font-size: 11px;
        font-weight: 600;
    }

    editor := LineEdit {
        height: 40px;
        min-width: 0px;
        preferred-width: 100%;
        horizontal-stretch: 1;
        text: root.value;
        placeholder-text: root.placeholder;
        edited => {
            root.edited(editor.text);
        }
    }
}

component StartupReadonlyValue inherits Rectangle {
    in property <string> value;

    min-width: 0px;
    preferred-width: 100%;
    horizontal-stretch: 1;
    height: 40px;
    border-color: #2b3139;
    border-width: 1px;
    border-radius: 6px;
    background: #171b22;

    Text {
        x: 12px;
        y: 11px;
        width: parent.width - 24px;
        text: root.value;
        color: #c0c7d2;
        font-size: 12px;
        overflow: elide;
    }
}

component StartupProjectRow inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    callback pressed();

    width: 100%;
    height: 42px;
    border-radius: 6px;
    background: root.selected ? #202733 : #151a20;

    Text {
        x: 12px;
        y: 12px;
        width: parent.width - 24px;
        text: root.label;
        color: root.selected ? #f3f5f8 : #c0c7d2;
        font-size: 12px;
        overflow: elide;
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            root.pressed();
        }
    }
}

export component StartupDialog inherits Rectangle {
    in property <bool> can-close;
    in property <bool> can-create;
    in property <bool> can-open-selected;
    in property <int> startup-tab;
    in property <[string]> startup-projects;
    in property <int> startup-selected-project;
    in property <string> parent-dir;
    in property <string> startup-name;
    in property <string> startup-width;
    in property <string> startup-height;
    in property <string> startup-fps;
    in property <string> startup-duration-minutes;
    in property <string> startup-preview-max-width;
    in property <string> startup-preview-max-height;
    in property <string> error-text;

    callback request-close();
    callback request-browse-parent();
    callback request-browse-existing-project();
    callback request-open-project();
    callback request-create-project();
    callback startup-tab-changed(int);
    callback startup-selected-project-changed(int);
    callback startup-name-edited(string);
    callback startup-width-edited(string);
    callback startup-height-edited(string);
    callback startup-fps-edited(string);
    callback startup-duration-minutes-edited(string);
    callback startup-preview-max-width-edited(string);
    callback startup-preview-max-height-edited(string);

    private property <length> content-pad: 20px;
    private property <length> row-gap: 12px;
    private property <length> scroll-bottom-pad: 84px;
    /// Tight vertical padding for Open/New row (centering handles alignment; no need for 10+10).
    private property <length> tab-bar-vpad: 6px;

    background: transparent;

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: #b0000000;
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            if (root.can-close) {
                root.request-close();
            }
        }
    }

    card := Rectangle {
        width: parent.width < 820px ? parent.width - 48px : 772px;
        height: parent.height < 760px ? parent.height - 40px : 712px;
        x: round(((parent.width - self.width) / 1px) / 2) * 1px;
        y: round(((parent.height - self.height) / 1px) / 2) * 1px;
        background: #14181f;
        border-color: #2b3139;
        border-width: 1px;
        border-radius: 10px;
        clip: true;

        VerticalBox {
            spacing: 0px;

            Rectangle {
                height: 82px;
                background: #14181f;

                RailSection {
                    width: 100%;
                    height: 100%;
                    pad-left: root.content-pad;
                    pad-top: 18px;
                    pad-right: root.content-pad;
                    pad-bottom: 16px;

                    HorizontalBox {
                        width: 100%;
                        height: 100%;
                        spacing: 12px;

                        VerticalBox {
                            horizontal-stretch: 1;
                            min-width: 0px;
                            spacing: 4px;

                            Text {
                                width: 100%;
                                horizontal-alignment: left;
                                text: "Project";
                                color: #f2f4f7;
                                font-size: 18px;
                                font-weight: 600;
                            }

                            Text {
                                width: 100%;
                                horizontal-alignment: left;
                                text: "Open an existing project or create a new one.";
                                color: #8d96a4;
                                font-size: 12px;
                                wrap: word-wrap;
                            }
                        }

                        if (root.can-close) : Button {
                            height: 36px;
                            text: "Close";
                            clicked => { root.request-close(); }
                        }
                    }
                }
            }

            Rectangle { height: 1px; background: #262c35; }

            // Tab row: alignment: center on tab-bar-inner — compact vertical padding (~60% of former 10+10).
            Rectangle {
                min-height: tab-bar-inner.preferred-height + root.tab-bar-vpad * 2;
                vertical-stretch: 0;
                preferred-height: tab-bar-inner.preferred-height + root.tab-bar-vpad * 2;
                background: #14181f;

                RailSection {
                    width: 100%;
                    height: 100%;
                    pad-left: root.content-pad;
                    pad-top: root.tab-bar-vpad;
                    pad-right: root.content-pad;
                    pad-bottom: root.tab-bar-vpad;

                    tab-bar-inner := HorizontalBox {
                        alignment: center;
                        width: 100%;
                        height: 100%;
                        spacing: 8px;

                        HorizontalBox {
                            spacing: 8px;

                            Button {
                                width: 76px;
                                height: 32px;
                                text: "Open";
                                primary: root.startup-tab == 0;
                                clicked => { root.startup-tab-changed(0); }
                            }

                            Button {
                                width: 76px;
                                height: 32px;
                                text: "New";
                                primary: root.startup-tab == 1;
                                clicked => { root.startup-tab-changed(1); }
                            }
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                            background: transparent;
                        }
                    }
                }
            }

            Rectangle { height: 1px; background: #262c35; }

            Rectangle {
                vertical-stretch: 1;
                background: #14181f;
                clip: true;

                if (root.startup-tab == 0) : RailSection {
                    width: 100%;
                    height: 100%;
                    pad-left: root.content-pad;
                    pad-top: root.content-pad;
                    pad-right: root.content-pad;
                    pad-bottom: root.content-pad;

                    VerticalBox {
                        width: 100%;
                        height: 100%;
                        spacing: 16px;

                        Text {
                            width: 100%;
                            height: 22px;
                            vertical-alignment: center;
                            horizontal-alignment: left;
                            text: "Projects";
                            color: #f2f4f7;
                            font-size: 14px;
                            font-weight: 600;
                        }

                        Text {
                            width: 100%;
                            horizontal-alignment: left;
                            text: "Choose a project from " + root.parent-dir + " or browse for another folder.";
                            color: #8d96a4;
                            font-size: 12px;
                            wrap: word-wrap;
                        }

                        Rectangle {
                            vertical-stretch: 1;
                            min-height: 220px;
                            min-width: 0px;
                            horizontal-stretch: 1;
                            preferred-width: 100%;
                            border-color: #2b3139;
                            border-width: 1px;
                            border-radius: 8px;
                            background: #171b22;
                            clip: true;

                            if (root.startup-projects.length > 0) : Rectangle {
                                x: 8px;
                                y: 8px;
                                width: parent.width - 16px;
                                height: parent.height - 16px;
                                background: transparent;
                                clip: true;

                                ListView {
                                    width: parent.width;
                                    height: parent.height;

                                    for project[index] in root.startup-projects : Rectangle {
                                        width: parent.width;
                                        height: 42px;
                                        background: transparent;

                                        StartupProjectRow {
                                            x: 6px;
                                            width: parent.width - 12px;
                                            label: project;
                                            selected: root.startup-selected-project == index;
                                            pressed => {
                                                root.startup-selected-project-changed(index);
                                            }
                                        }
                                    }
                                }
                            }

                            if (root.startup-projects.length == 0) : Rectangle {
                                background: transparent;

                                Text {
                                    x: 12px;
                                    y: 18px;
                                    width: parent.width - 24px;
                                    horizontal-alignment: left;
                                    text: "No projects found in the default projects folder yet.";
                                    color: #8d96a4;
                                    font-size: 12px;
                                    wrap: word-wrap;
                                }
                            }
                        }

                        if (root.error-text != "") : Text {
                            width: 100%;
                            horizontal-alignment: left;
                            text: root.error-text;
                            color: #e29a9a;
                            font-size: 12px;
                            wrap: word-wrap;
                        }
                    }
                }

                if (root.startup-tab == 1) : RailSection {
                    width: 100%;
                    height: 100%;
                    pad-left: root.content-pad;
                    pad-top: root.content-pad;
                    pad-right: root.content-pad;
                    pad-bottom: root.content-pad;

                    new-project-scroll := ScrollView {
                        width: 100%;
                        height: 100%;
                        viewport-width: self.width;
                        viewport-height: new-project-content.height;
                        horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

                        new-project-content := Rectangle {
                            background: transparent;
                            width: new-project-scroll.width;
                            height: new-project-vbox.preferred-height + root.scroll-bottom-pad;

                            new-project-vbox := VerticalBox {
                                width: 100%;
                                spacing: root.row-gap;
                                min-width: 0px;
                                horizontal-stretch: 1;

                                Text {
                                    height: 22px;
                                    vertical-alignment: center;
                                    horizontal-alignment: left;
                                    text: "New Project";
                                    color: #f2f4f7;
                                    font-size: 14px;
                                    font-weight: 600;
                                }

                                Text {
                                    horizontal-alignment: left;
                                    text: "Choose the parent folder and project settings, then create a new project directory.";
                                    color: #8d96a4;
                                    font-size: 12px;
                                    wrap: word-wrap;
                                }

                                Text {
                                    height: 18px;
                                    vertical-alignment: center;
                                    horizontal-alignment: left;
                                    text: "Parent Folder";
                                    color: #8d96a4;
                                    font-size: 11px;
                                    font-weight: 600;
                                }

                                HorizontalBox {
                                    spacing: 8px;
                                    min-width: 0px;

                                    StartupReadonlyValue {
                                        horizontal-stretch: 1;
                                        min-width: 0px;
                                        value: root.parent-dir;
                                    }

                                    Button {
                                        height: 36px;
                                        text: "Browse";
                                        clicked => { root.request-browse-parent(); }
                                    }
                                }

                                StartupFieldRow {
                                    label: "Project Name";
                                    value: root.startup-name;
                                    placeholder: "My New Project";
                                    edited(value) => { root.startup-name-edited(value); }
                                }

                                HorizontalBox {
                                    spacing: root.row-gap;
                                    min-width: 0px;

                                    StartupFieldRow {
                                        min-width: 0px;
                                        preferred-width: 0px;
                                        horizontal-stretch: 1;
                                        label: "Width";
                                        value: root.startup-width;
                                        placeholder: "1920";
                                        edited(value) => { root.startup-width-edited(value); }
                                    }

                                    StartupFieldRow {
                                        min-width: 0px;
                                        preferred-width: 0px;
                                        horizontal-stretch: 1;
                                        label: "Height";
                                        value: root.startup-height;
                                        placeholder: "1080";
                                        edited(value) => { root.startup-height-edited(value); }
                                    }
                                }

                                HorizontalBox {
                                    spacing: root.row-gap;
                                    min-width: 0px;

                                    StartupFieldRow {
                                        min-width: 0px;
                                        preferred-width: 0px;
                                        horizontal-stretch: 1;
                                        label: "FPS";
                                        value: root.startup-fps;
                                        placeholder: "60";
                                        edited(value) => { root.startup-fps-edited(value); }
                                    }

                                    StartupFieldRow {
                                        min-width: 0px;
                                        preferred-width: 0px;
                                        horizontal-stretch: 1;
                                        label: "Duration (Minutes)";
                                        value: root.startup-duration-minutes;
                                        placeholder: "1";
                                        edited(value) => { root.startup-duration-minutes-edited(value); }
                                    }
                                }

                                HorizontalBox {
                                    spacing: root.row-gap;
                                    min-width: 0px;

                                    StartupFieldRow {
                                        min-width: 0px;
                                        preferred-width: 0px;
                                        horizontal-stretch: 1;
                                        label: "Preview Max Width";
                                        value: root.startup-preview-max-width;
                                        placeholder: "960";
                                        edited(value) => { root.startup-preview-max-width-edited(value); }
                                    }

                                    StartupFieldRow {
                                        min-width: 0px;
                                        preferred-width: 0px;
                                        horizontal-stretch: 1;
                                        label: "Preview Max Height";
                                        value: root.startup-preview-max-height;
                                        placeholder: "540";
                                        edited(value) => { root.startup-preview-max-height-edited(value); }
                                    }
                                }

                                if (root.error-text != "") : Text {
                                    horizontal-alignment: left;
                                    text: root.error-text;
                                    color: #e29a9a;
                                    font-size: 12px;
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }
                }
            }

            Rectangle { height: 1px; background: #262c35; }

            // Footer: same as tab row — alignment: center on cross-axis so buttons sit between separators.
            Rectangle {
                min-height: 58px;
                vertical-stretch: 0;
                preferred-height: footer-bar-inner.preferred-height + 22px;
                background: #14181f;

                RailSection {
                    width: 100%;
                    height: 100%;
                    pad-left: root.content-pad;
                    pad-top: 10px;
                    pad-right: root.content-pad;
                    pad-bottom: 12px;

                    footer-bar-inner := HorizontalBox {
                        alignment: center;
                        width: 100%;
                        height: 100%;
                        spacing: 8px;

                        Rectangle {
                            horizontal-stretch: 1;
                            background: transparent;
                        }

                        if (root.startup-tab == 0) : Button {
                            height: 36px;
                            text: "Browse Folder";
                            clicked => { root.request-browse-existing-project(); }
                        }

                        if (root.startup-tab == 0) : Button {
                            height: 36px;
                            text: "Open Selected";
                            enabled: root.can-open-selected;
                            clicked => { root.request-open-project(); }
                        }

                        if (root.startup-tab == 1) : Button {
                            height: 36px;
                            text: "Create Project";
                            enabled: root.can-create;
                            clicked => { root.request-create-project(); }
                        }
                    }
                }
            }
        }
    }
}
