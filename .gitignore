# Rust / Cargo
/target/
**/*.rs.bk

# Environment & Secrets
.env
.env.local
.env.*.local
credentials.json
**/credentials.json
*credentials*.json
*.secret
*.secrets
*.key
*.apikey

# IDE / Editor
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Build artifacts
*.exe
*.dll
*.so
*.dylib
*.pdb

# Logs
*.log
logs/

# User projects (contains media assets, project.json, etc.)
# These are created by the application and should not be committed
/projects/
/test-projects/

# Repo-local LatentSlate runtime state.
# Keep the folder structure visible, but keep user providers, credentials, and
# caches out of git.
/.latentslate/*
!/.latentslate/.gitkeep
!/.latentslate/providers/
/.latentslate/providers/*
!/.latentslate/providers/.gitkeep
!/.latentslate/secrets/
/.latentslate/secrets/*
!/.latentslate/secrets/.gitkeep
!/.latentslate/cache/
/.latentslate/cache/*
!/.latentslate/cache/.gitkeep

# Portable app data root used next to the executable. Ignore it here too in
# case LATENTSLATE_HOME points at the repo during development.
/LatentSlateData/

# Local/personal ComfyUI workflows.
# Keep this deny-by-default and opt in only blessed default workflows.
/workflows/*
!/workflows/Mock Video Workflow API.json
!/workflows/Mock Video Workflow API_manifest.json
!/workflows/sdxl_simple_example_API.json
!/workflows/sdxl_simple_example_API_manifest.json
!/workflows/SDXL-VANILLA-API.json
!/workflows/SDXL-VANILLA-API_manifest.json

# OS generated
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

.tmp/*

.venv
generate-git-history-video-here.bat
